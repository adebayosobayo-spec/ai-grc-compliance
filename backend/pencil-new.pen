                              "name": "sec2Title",
                              "fill": "#1e293b",
                              "content": "2. Roles and Responsibilities",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "700"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "0pkQw",
                          "name": "sec2Body",
                          "fill": "#374151",
                          "content": "- Chief Information Security Officer (CISO): Overall accountability for the ISMS and policy compliance\n- IT Security Team: Day-to-day implementation and monitoring of security controls\n- Department Heads: Ensure staff within their function comply with this policy\n- All Staff: Responsible for protecting information assets under their custodianship",
