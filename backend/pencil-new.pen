                              "name": "sec1Title",
                              "fill": "#1e293b",
                              "content": "1. Purpose and Scope",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "700"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "Hd3DM",
                          "name": "sec1Body",
                          "fill": "#374151",
                          "content": "This policy establishes the framework for information security management at Acme Financial Services Ltd. It applies to all employees, contractors, and third parties who access, process, or store organisational data and systems. The objective is to protect the confidentiality, integrity, and availability of information assets in accordance with ISO/IEC 27001:2022.",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "tUOQs",
